# ─────────────────────────────────────────────────────────────────────────────
# StableEscrow UAE – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Your deployer wallet private key (no 0x prefix)
# Fund it with testnet MATIC from: https://faucet.polygon.technology/
PRIVATE_KEY=your_wallet_private_key_here

# USDC contract address on Polygon Amoy testnet
# Get testnet USDC from the Polygon faucet or deploy MockERC20
USDC_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582

# (Filled in after deployment – used by frontend)
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582
NEXT_PUBLIC_CHAIN_ID=80002
NEXT_PUBLIC_RPC_URL=https://rpc-amoy.polygon.technology

# Optional: Polygonscan API key for contract verification
# Get one free at: https://polygonscan.com/login
POLYGONSCAN_API_KEY=
